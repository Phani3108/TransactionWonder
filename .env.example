# TransactionWonder — local development environment template.
# Copy to `.env` and fill in the blanks. Never commit the filled version.

# -------- Core ----------------------------------------------------------------

# Postgres connection string used by the API + migrations.
DATABASE_URL=postgres://transactionwonder:transactionwonder_password@localhost:5432/transactionwonder

# API port (default 4004). Dashboard expects the API here unless you
# override in dashboard/.env.
PORT=4004

# --- Auth / JWT (P1-7) -------------------------------------------------------

# Used to sign access + refresh tokens. Rotate on compromise.
JWT_SECRET=change-me-to-a-long-random-string

# Token lifetimes. 1h access + 30d refresh is the default.
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# --- LLM (DeepSeek is the primary; OpenAI SDK is compatibility layer) --------

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=

# --- Observability (Opik) ----------------------------------------------------

OPIK_BASE_URL=http://localhost:5173/api

# --- OAuth token-at-rest encryption (P1-2) -----------------------------------

# 32 bytes of entropy, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
OAUTH_ENCRYPTION_KEY=

# --- Integrations (all optional; each has a synthetic fallback) --------------

PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_ACCEPT_UNVERIFIED=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=
QUICKBOOKS_ENV=sandbox

XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=
# Set to 1 for the Xero Demo Company dev path (P2-13).
XERO_DEMO_MODE=0

GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
GOOGLE_APPLICATION_CREDENTIALS=
